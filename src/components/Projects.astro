---
import projectsData from "../data/projects.json";
---

<section id="projects">
    <div class="container">
        <h2>Projects</h2>
        <div class="projects-grid">
            {
                projectsData.map((project) => (
                    <div class="project-card glass-card">
                        <div class="card-header">
                            <h3>{project.title}</h3>
                            <div class="links">
                                {project.siteLink && (
                                    <a
                                        href={project.siteLink}
                                        class="icon-link icon-link--site"
                                        aria-label="View Site"
                                        target="_blank"
                                    >
                                        <span class="link-icon">↗</span>
                                        <span>Site</span>
                                    </a>
                                )}
                                {project.codeLink && (
                                    <a
                                        href={project.codeLink}
                                        class="icon-link icon-link--code"
                                        aria-label="View Code"
                                        target="_blank"
                                    >
                                        <span class="link-icon">{`{ }`}</span>
                                        <span>Code</span>
                                    </a>
                                )}
                            </div>
                        </div>
                        <p class="desc">{project.desc}</p>
                        <div class="details">
                            <p>{project.details}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2rem;
    }

    .project-card {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .card-header h3 {
        margin: 0;
        font-size: 1.5rem;
        color: var(--text-primary);
    }

    .links {
        display: flex;
        gap: 1rem;
    }

    .icon-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        padding: 0.35rem 0.85rem;
        border-radius: 100px;
        border: 1.5px solid;
        transition: all var(--transition-fast);
        text-decoration: none;
        white-space: nowrap;
    }

    .icon-link::after {
        display: none; /* disable global underline animation */
    }

    .link-icon {
        font-size: 0.9rem;
        line-height: 1;
    }

    .icon-link--site {
        color: var(--accent-primary);
        border-color: var(--accent-primary);
        background: rgba(56, 189, 248, 0.08);
    }

    .icon-link--site:hover {
        background: rgba(56, 189, 248, 0.18);
        box-shadow: 0 0 12px rgba(56, 189, 248, 0.35);
        transform: translateY(-2px);
        color: var(--accent-primary);
    }

    .icon-link--code {
        color: var(--accent-secondary);
        border-color: var(--accent-secondary);
        background: rgba(129, 140, 248, 0.08);
    }

    .icon-link--code:hover {
        background: rgba(129, 140, 248, 0.18);
        box-shadow: 0 0 12px rgba(129, 140, 248, 0.35);
        transform: translateY(-2px);
        color: var(--accent-secondary);
    }

    .desc {
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
        flex-grow: 1;
    }

    .details {
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid var(--bg-tertiary);
        font-size: 0.9rem;
        color: var(--text-secondary);
        opacity: 0.8;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Use Batch to handle elements individually and reliably
    ScrollTrigger.batch(".project-card", {
        onEnter: (batch) => {
            gsap.to(batch, {
                opacity: 1,
                y: 0,
                stagger: 0.15,
                duration: 0.8,
                ease: "power3.out",
                overwrite: true, // Ensure we take control
            });
        },
        // Also handle when they are already in view on load (refresh)
        onRefresh: (batch) => {
            // Only if they are supposed to be visible
            // But simpler: just let onEnter handle it, ScrollTrigger usually calls onEnter for in-view elements on refresh
        },
        start: "top 85%",
        once: true, // Only animate once
    });

    // Set initial state via GSAP to prevent CSS conflicts
    gsap.set(".project-card", {
        y: 50,
        opacity: 0,
    });
</script>
