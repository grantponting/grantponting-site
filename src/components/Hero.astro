<section id="hero" class="hero">
    <div class="container hero-content">
        <span class="eyebrow">Hello, I'm</span>
        <h1>Grant <span class="text-gradient">Ponting</span></h1>
        <p class="lead">Software Developer</p>
        <p class="sub-lead">
            Building reliable web applications with expertise in full-stack
            development, automation, and software quality.
        </p>

        <div class="cta-group">
            <a href="#projects" class="btn btn-primary">View Work</a>
            <a href="/grant_resume.pdf" class="btn btn-outline" download
                >Download CV</a
            >
        </div>
    </div>

    <canvas id="hero-canvas"></canvas>

    <div class="background-glow"></div>
</section>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        padding-top: 80px; /* Offset for navbar */
        overflow: hidden;
    }

    #hero-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1; /* Behind content but in front of base background */
        opacity: 0.4;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 800px;
        will-change: transform;
    }

    .eyebrow {
        color: var(--accent-primary);
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: block;
    }

    h1 {
        font-size: 5rem;
        margin-bottom: 1.5rem;
        line-height: 1.1;
    }

    .lead {
        font-size: 1.5rem;
        color: var(--text-secondary);
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .sub-lead {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 2.5rem;
        max-width: 600px;
        opacity: 0.8;
    }

    .cta-group {
        display: flex;
        gap: 1rem;
    }

    .background-glow {
        position: absolute;
        top: 50%;
        right: -10%;
        transform: translateY(-50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(
            circle,
            rgba(56, 189, 248, 0.15) 0%,
            rgba(15, 23, 42, 0) 70%
        );
        z-index: 0;
        pointer-events: none;
        will-change: transform;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 3.5rem;
        }

        .lead {
            font-size: 1.25rem;
        }
    }
</style>

<script>
    // Reduced particle count restored to original
    // Canvas Particle Animation — optimised with spatial grid
    const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
    if (canvas) {
        const ctx = canvas.getContext("2d");
        let w = (canvas.width = window.innerWidth);
        let h = (canvas.height = window.innerHeight);

        // Restored to original counts
        const PARTICLE_COUNT = window.innerWidth < 768 ? 40 : 100;
        // Reduced connection distance → fewer pairs qualify per frame
        const CONNECTION_DIST = 120;
        const CONNECTION_DIST_SQ = CONNECTION_DIST * CONNECTION_DIST;

        // Spatial grid for O(n) neighbour lookup instead of O(n²)
        const CELL_SIZE = CONNECTION_DIST;
        let gridCols = 0;
        let gridRows = 0;
        let grid: number[][] = [];

        function buildGrid() {
            gridCols = Math.ceil(w / CELL_SIZE) + 1;
            gridRows = Math.ceil(h / CELL_SIZE) + 1;
            grid = Array.from({ length: gridCols * gridRows }, () => []);
        }

        function clearGrid() {
            for (let i = 0; i < grid.length; i++) grid[i].length = 0;
        }

        function cellIndex(cx: number, cy: number) {
            return cy * gridCols + cx;
        }

        class Particle {
            x: number;
            y: number;
            vx: number;
            vy: number;
            size: number;

            constructor() {
                this.x = Math.random() * w;
                this.y = Math.random() * h;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 2 + 1;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;

                if (this.x < 0) this.x = w;
                if (this.x > w) this.x = 0;
                if (this.y < 0) this.y = h;
                if (this.y > h) this.y = 0;
            }

            draw() {
                if (!ctx) return;
                ctx.fillStyle = "rgba(56, 189, 248, 0.6)";
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        const particles: Particle[] = [];
        for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle());
        buildGrid();

        let rafId: number;
        let paused = false;

        // Pause animation when hero scrolls out of view — saves CPU/GPU
        const observer = new IntersectionObserver(
            (entries) => {
                paused = !entries[0].isIntersecting;
                if (!paused && !rafId) rafId = requestAnimationFrame(animate);
            },
            { threshold: 0 },
        );
        observer.observe(canvas);

        ctx!.lineWidth = 1;

        function animate() {
            if (!ctx) return;
            if (paused) {
                // @ts-ignore
                rafId = 0;
                return;
            }

            ctx.clearRect(0, 0, w, h);

            // --- Populate spatial grid ---
            clearGrid();
            for (let i = 0; i < particles.length; i++) {
                const p = particles[i];
                const cx = Math.floor(p.x / CELL_SIZE);
                const cy = Math.floor(p.y / CELL_SIZE);
                grid[cellIndex(cx, cy)].push(i);
            }

            // --- Update, draw particles & connections ---
            for (let i = 0; i < particles.length; i++) {
                const p = particles[i];
                p.update();
                p.draw();

                // Check only neighbouring grid cells
                const cx = Math.floor(p.x / CELL_SIZE);
                const cy = Math.floor(p.y / CELL_SIZE);

                for (let dcx = -1; dcx <= 1; dcx++) {
                    for (let dcy = -1; dcy <= 1; dcy++) {
                        const nx = cx + dcx;
                        const ny = cy + dcy;
                        if (
                            nx < 0 ||
                            nx >= gridCols ||
                            ny < 0 ||
                            ny >= gridRows
                        )
                            continue;
                        const cell = grid[cellIndex(nx, ny)];
                        for (let k = 0; k < cell.length; k++) {
                            const j = cell[k];
                            if (j <= i) continue; // avoid duplicate pairs
                            const p2 = particles[j];
                            const dx = p.x - p2.x;
                            const dy = p.y - p2.y;
                            const distSq = dx * dx + dy * dy;
                            if (distSq < CONNECTION_DIST_SQ) {
                                const dist = Math.sqrt(distSq);
                                ctx.strokeStyle = `rgba(56, 189, 248, ${0.2 * (1 - dist / CONNECTION_DIST)})`;
                                ctx.beginPath();
                                ctx.moveTo(p.x, p.y);
                                ctx.lineTo(p2.x, p2.y);
                                ctx.stroke();
                            }
                        }
                    }
                }
            }

            rafId = requestAnimationFrame(animate);
        }

        rafId = requestAnimationFrame(animate);

        window.addEventListener("resize", () => {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
            buildGrid();
        });
    }
</script>
