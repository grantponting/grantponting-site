---

<section id="hero" class="hero">
    <div class="container hero-content">
        <span class="eyebrow">Hello, I'm</span>
        <h1>Grant <span class="text-gradient">Ponting</span></h1>
        <p class="lead">Software Developer</p>
        <p class="sub-lead">
            Building reliable web applications with expertise in full-stack
            development, automation, and software quality.
        </p>

        <div class="cta-group">
            <a href="#projects" class="btn btn-primary">View Work</a>
            <a href="/grant_resume.pdf" class="btn btn-outline" download
                >Download CV</a
            >
        </div>
    </div>

    <canvas id="hero-canvas"></canvas>

    <div class="background-glow"></div>
</section>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        padding-top: 80px; /* Offset for navbar */
        overflow: hidden;
    }

    #hero-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1; /* Behind content but in front of base background */
        opacity: 0.4;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 800px;
    }

    .eyebrow {
        color: var(--accent-primary);
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: block;
    }

    h1 {
        font-size: 5rem;
        margin-bottom: 1.5rem;
        line-height: 1.1;
    }

    .lead {
        font-size: 1.5rem;
        color: var(--text-secondary);
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .sub-lead {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 2.5rem;
        max-width: 600px;
        opacity: 0.8;
    }

    .cta-group {
        display: flex;
        gap: 1rem;
    }

    .background-glow {
        position: absolute;
        top: 50%;
        right: -10%;
        transform: translateY(-50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(
            circle,
            rgba(56, 189, 248, 0.15) 0%,
            rgba(15, 23, 42, 0) 70%
        );
        z-index: 0;
        pointer-events: none;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 3.5rem;
        }

        .lead {
            font-size: 1.25rem;
        }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const hero = document.querySelector(".hero");
    const glow = document.querySelector(".background-glow");

    // Parallax Effect
    if (hero && glow) {
        gsap.to(glow, {
            yPercent: 70,
            scale: 1.2,
            ease: "none",
            scrollTrigger: {
                trigger: hero,
                start: "top top",
                end: "bottom top",
                scrub: true,
            },
        });

        gsap.to(".hero-content", {
            yPercent: -50,
            opacity: 0,
            ease: "none",
            scrollTrigger: {
                trigger: hero,
                start: "top top",
                end: "bottom top",
                scrub: true,
            },
        });
    }

    // Canvas Particle Animation
    const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
    if (canvas) {
        const ctx = canvas.getContext("2d");
        let w = (canvas.width = window.innerWidth);
        let h = (canvas.height = window.innerHeight);

        class Particle {
            x: number;
            y: number;
            vx: number;
            vy: number;
            size: number;

            constructor() {
                this.x = Math.random() * w;
                this.y = Math.random() * h;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 3 + 1; // Thicker particles (1-4px)
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;

                if (this.x < 0) this.x = w;
                if (this.x > w) this.x = 0;
                if (this.y < 0) this.y = h;
                if (this.y > h) this.y = 0;
            }

            draw() {
                if (!ctx) return;
                ctx.fillStyle = "rgba(56, 189, 248, 0.6)"; // Slightly increased opacity
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        const particles: Particle[] = [];
        const particleCount = window.innerWidth < 768 ? 40 : 100; // More particles on desktop

        for (let i = 0; i < particleCount; i++) {
            particles.push(new Particle());
        }

        function animate() {
            if (!ctx) return;
            ctx.clearRect(0, 0, w, h);

            particles.forEach((p) => {
                p.update();
                p.draw();

                // Draw connections
                particles.forEach((p2) => {
                    const dx = p.x - p2.x;
                    const dy = p.y - p2.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < 180) {
                        // Increased connection distance
                        ctx.strokeStyle = `rgba(56, 189, 248, ${0.2 * (1 - dist / 180)})`; // Slightly more visible
                        ctx.lineWidth = 1.5; // Thicker lines
                        ctx.beginPath();
                        ctx.moveTo(p.x, p.y);
                        ctx.lineTo(p2.x, p2.y);
                        ctx.stroke();
                    }
                });
            });

            requestAnimationFrame(animate);
        }

        animate();

        window.addEventListener("resize", () => {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
        });
    }
</script>
